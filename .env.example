# Copy to .env.local for local development. .env.local is gitignored.

# Server-side only; the pipeline calls OpenAI from app/api/generate-room.
# Not needed on a deployed build unless room generation is switched on below.
OPENAI_API_KEY=

# "fintalo" = the addressed build. Unset or "neutral" = the unaddressed one.
NEXT_PUBLIC_BRAND=fintalo

# Live room generation. Leave unset when deploying: the pipeline writes each
# finished room to data/rooms/generated/, and that filesystem is read-only on
# serverless hosts, so a deployed run spends an API call and then fails. It also
# closes an unauthenticated endpoint that costs money per call.
# Set to "true" locally to run the full pipeline.
NEXT_PUBLIC_ENABLE_ROOM_GENERATION=
